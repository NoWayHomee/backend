  "info": {
    "title": "NoWayHome API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "customer@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123",
            "minLength": 8
          },
          "fullName": {
            "type": "string",
            "example": "Nguyen Van A"
          },
          "phone": {
            "type": "string",
            "example": "+84901234567"
          },
          "userType": {
            "type": "string",
            "enum": [
              "customer",
              "partner",
              "admin"
            ],
            "example": "customer"
          },
          "businessName": {
            "type": "string",
            "example": "Nguyen Van A Travel Co."
          },
          "businessType": {
            "type": "string",
            "enum": [
              "individual",
              "company"
            ],
            "example": "individual"
          }
        },
        "required": [
          "email",
          "password",
          "fullName",
          "phone",
          "userType"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "customer@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123",
            "minLength": 8
          },
          "deviceName": {
            "type": "string",
            "example": "Chrome on Windows"
          },
          "deviceType": {
            "type": "string",
            "enum": [
              "web",
              "ios",
              "android",
              "other"
            ],
            "example": "web"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "UpdateKycStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "approved",
              "rejected"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "UpdatePropertyStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suspended",
              "pending_review",
              "rejected"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "CreatePropertyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "NoWayHome Central Hotel"
          },
          "propertyType": {
            "type": "string",
            "enum": [
              "hotel",
              "homestay",
              "resort",
              "apartment",
              "villa",
              "hostel"
            ],
            "example": "hotel"
          },
          "city": {
            "type": "string",
            "example": "Ho Chi Minh City"
          },
          "address": {
            "type": "string",
            "example": "12 Nguyen Hue, District 1"
          },
          "latitude": {
            "type": "number",
            "example": 10.7758439
          },
          "longitude": {
            "type": "number",
            "example": 106.7017555
          },
          "description": {
            "type": "string",
            "example": "Modern hotel in the city center."
          }
        },
        "required": [
          "name",
          "propertyType",
          "city",
          "address",
          "latitude",
          "longitude"
        ]
      },
      "UpdatePropertyDto": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "example": "A centrally located hotel for business and leisure travelers."
          },
          "check_in_time": {
            "type": "string",
            "example": "14:00"
          },
          "check_out_time": {
            "type": "string",
            "example": "12:00"
          }
        }
      },
      "UpsertPropertyPoliciesDto": {
        "type": "object",
        "properties": {
          "cancellation_type": {
            "type": "string",
            "enum": [
              "free",
              "flexible",
              "moderate",
              "strict",
              "non_refundable"
            ]
          },
          "free_cancel_hours": {
            "type": "number",
            "example": 24
          },
          "cancel_penalty_percent": {
            "type": "number",
            "example": 50
          },
          "min_stay_nights": {
            "type": "number",
            "example": 1
          },
          "max_stay_nights": {
            "type": "number",
            "example": 30
          },
          "check_in_from": {
            "type": "string",
            "example": "14:00"
          },
          "check_in_until": {
            "type": "string",
            "example": "22:00"
          },
          "check_out_from": {
            "type": "string",
            "example": "00:00"
          },
          "check_out_until": {
            "type": "string",
            "example": "12:00"
          },
          "early_check_in_allowed": {
            "type": "boolean",
            "example": false
          },
          "early_check_in_fee": {
            "type": "number",
            "example": 150000
          },
          "late_check_out_allowed": {
            "type": "boolean",
            "example": false
          },
          "late_check_out_fee": {
            "type": "number",
            "example": 150000
          },
          "pets_allowed": {
            "type": "boolean",
            "example": false
          },
          "smoking_allowed": {
            "type": "boolean",
            "example": false
          },
          "children_allowed": {
            "type": "boolean",
            "example": true
          },
          "no_show_penalty_type": {
            "type": "string",
            "enum": [
              "full_amount",
              "first_night",
              "percent"
            ]
          },
          "instant_confirmation": {
            "type": "boolean",
            "example": true
          },
          "deposit_required": {
            "type": "boolean",
            "example": false
          },
          "deposit_type": {
            "type": "string",
            "enum": [
              "percent",
              "fixed"
            ]
          },
          "deposit_value": {
            "type": "number",
            "example": 10
          },
          "accepted_payment_methods": {
            "example": [
              "credit_card",
              "pay_later"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "breakfast_included": {
