    "/properties/search": {
      "get": {
        "operationId": "PropertiesController_search",
        "parameters": [
          {
            "name": "city",
            "required": false,
            "in": "query",
            "schema": {
              "example": "Ho Chi Minh City",
              "type": "string"
            }
          },
          {
            "name": "star_rating",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 5,
              "example": 4,
              "type": "number"
            }
          },
          {
            "name": "min_price",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "example": 500000,
              "type": "number"
            }
          },
          {
            "name": "max_price",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "example": 2500000,
              "type": "number"
            }
          },
          {
            "name": "check_in",
            "required": false,
            "in": "query",
            "schema": {
              "example": "2026-06-01",
              "type": "string"
            }
          },
          {
            "name": "check_out",
            "required": false,
            "in": "query",
            "schema": {
              "example": "2026-06-03",
              "type": "string"
            }
          },
          {
            "name": "rooms_needed",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns active properties matching search and availability."
          }
        },
        "summary": "Search public properties",
        "tags": [
          "Properties"
        ]
      }
    },
